POSTGRES_DB=notify_center
POSTGRES_USER=notify
POSTGRES_PASSWORD=change-this-postgres-password

ASPNETCORE_URLS=http://+:17052
DATABASE_URL=

JWT_ISSUER=NotifyCenter
JWT_AUDIENCE=NotifyCenterClients
JWT_SIGNING_KEY=replace-with-a-32-character-secret
JWT_EXPIRES_MINUTES=1440

NOTIFICATION_POLL_SECONDS=30

TELEGRAM_BOT_TOKEN=123456789:replace-with-your-bot-token
TELEGRAM_DEFAULT_CHAT_ID=-1001234567890
TELEGRAM_PARSE_MODE=HTML

# VITE_BASE_PATH: the base URL baked into the browser-side app (what the browser sees).
# NGINX_BASE_PATH: what nginx inside Docker actually receives (after reverse proxy prefix stripping).
#
# Synology reverse proxy strips the prefix before forwarding, so:
#   VITE_BASE_PATH=/NotifyCenter/   ← browser URLs include /NotifyCenter/
#   NGINX_BASE_PATH=/               ← nginx sees paths WITHOUT the prefix
#
# Direct port access (no proxy):
#   VITE_BASE_PATH=/
#   NGINX_BASE_PATH=/
VITE_BASE_PATH=/
NGINX_BASE_PATH=/
